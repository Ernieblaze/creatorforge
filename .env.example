# ── Supabase ─────────────────────────────────────────────
# Create a free project at https://supabase.com, then copy from
# Project Settings → API. Enable Google auth under Authentication → Providers.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── AI Provider ──────────────────────────────────────────
# Pick one: groq (free tier, fastest) | openai | anthropic
# Get a free Groq key at https://console.groq.com/keys
VITE_AI_PROVIDER=groq
VITE_AI_API_KEY=
# Optional model override (defaults: groq→llama-3.3-70b-versatile,
# openai→gpt-4o-mini, anthropic→claude-haiku-4-5-20251001)
VITE_AI_MODEL=

# ── Paystack (Premium subscriptions) ─────────────────────
# Public key from Paystack Dashboard → Settings → API Keys.
# Create two Plans (₦3,000 monthly, ₦30,000 yearly) under
# Payments → Plans and paste their PLN_ codes below.
# The SECRET key goes in Supabase secrets, never here.
VITE_PAYSTACK_PUBLIC_KEY=
VITE_PAYSTACK_PLAN_MONTHLY=
VITE_PAYSTACK_PLAN_YEARLY=

# ── Admin ────────────────────────────────────────────────
# Email that unlocks the /admin dashboard (VITE_ADMIN_EMAILS also
# accepted as a comma-separated list for multiple admins)
VITE_ADMIN_EMAIL=ernieblazze@gmail.com
